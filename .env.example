# Bazowy URL API GameHive.
#
# DEV: zostaw PUSTE — żądania idą względnie (/api/...) na ten sam origin (:5173)
# i są przekazywane do backendu przez proxy Vite (server.proxy w vite.config.ts),
# dzięki czemu nie ma problemów z CORS. Backend dev domyślnie pod :8080;
# inny adres ustaw przez VITE_API_PROXY_TARGET.
#
# PROD: ustaw pełny URL backendu, np. https://api.gamehive.example.
VITE_API_BASE_URL=

# Opcjonalnie: cel proxy w dev (domyślnie http://localhost:8080)
# VITE_API_PROXY_TARGET=http://localhost:8080
